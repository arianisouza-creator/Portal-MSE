# Copie para .env e ajuste os valores. O .env NAO deve ser versionado.

# Conexao MySQL (producao)
DB_HOST=dbsubdominios.portalmse.com.br
DB_PORT=3306
DB_USER=controle_internet_prod
DB_PASSWORD=controle_internet@2026
DB_NAME=controle_internet

# API de passagens (servico externo, permanece o mesmo)
PASSAGENS_API_BASE_URL=https://portalmse.com.br/microservices/hub_mse/api_passagens
PASSAGENS_API_TOKEN=

# Base da API usada pelo front-end.
# Vazio = mesma origem (recomendado): as chamadas viram /rest/v1/<tabela>.
PORTAL_API_BASE_URL=

# Servidor
PORT=8000
FLASK_DEBUG=0

# Auto-deploy (webhook do GitHub)
# Segredo compartilhado entre o webhook do GitHub e o listener (webhook.py).
GITHUB_WEBHOOK_SECRET=
DEPLOY_BRANCH=main
WEBHOOK_PORT=5061
